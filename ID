<head>

  <title>Inversión en I+D: IA en México</title>
  <link>
  <style>
    :root {
      --navy: #0b1f3a;
      --blue: #1c4b82;
      --magenta: #d4006e;
      --pink: #ee3d8f;
      --white: #ffffff;
      --off: #f4f7fb;
      --text: #1a2a3a;
      --mid: #3d4f6a;
      --border: #dde7f3;
    }

    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background: var(--off);
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    /* HERO */
    .hero {
      position: relative;
      min-height: 52vh;
      background: var(--navy);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 72px 24px 64px;
    }
    .stats-title {
      text-align: center;
      color: white;
      font-size: 2.2rem;
      font-weight: 700;
      
      margin-bottom: 24px;
      letter-spacing: 0.05em;
    }
    .stats-title span {
      color: var(--pink);
    }

    .hero-bg {
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 75% 60% at 72% 38%, rgba(28, 75, 130, .65) 0%, transparent 65%), radial-gradient(ellipse 55% 75% at 10% 85%, rgba(212, 0, 110, .30) 0%, transparent 58%);
    }

    .arc {
      position: absolute;
      border-radius: 50%;
      pointer-events: none;
      animation: arc-pulse 9s ease-in-out infinite;
    }

    .arc-1 {
      width: 900px;
      height: 900px;
      border: 1px solid rgba(212, 0, 110, .13);
      bottom: -380px;
      left: -260px;
    }

    .arc-2 {
      width: 580px;
      height: 580px;
      border: 1px solid rgba(212, 0, 110, .20);
      bottom: -200px;
      left: -100px;
      animation-delay: 2.5s;
    }

    @keyframes arc-pulse {

      0%,
      100% {
        transform: scale(1);
        opacity: .7;
      }

      50% {
        transform: scale(1.05);
        opacity: 1;
      }
    }

    .hero-content {
      position: relative;
      z-index: 2;
      text-align: center;
      max-width: 780px;
    }

    .hero-logos {
      position: absolute;
      top: 24px;
      left: 24px;
      display: flex;
      gap: 20px;
      z-index: 3;
    }

    .hero-logos img {
      height: 50px;
      width: auto;
      filter: brightness(1.1);
    }

    .hero-sup {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .24em;
      text-transform: uppercase;
      color: rgba(255, 255, 255, .35);
      margin-bottom: 28px;
    }

    .hero-sup::before,
    .hero-sup::after {
      content: '';
      display: block;
      width: 26px;
      height: 1px;
      background: rgba(255, 255, 255, .2);
    }

    .hero-title {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(2rem, 5vw, 3.4rem);
      font-weight: 900;
      color: var(--white);
      line-height: 1.15;
      margin-bottom: 10px;
    }

    .hero-title span {
      color: var(--pink);
    }

    .hero-rule {
      width: 50px;
      height: 3px;
      background: linear-gradient(90deg, var(--magenta), var(--pink));
      border-radius: 2px;
      margin: 18px auto;
    }

    .hero-desc {
      font-size: clamp(.9rem, 2vw, 1.05rem);
      color: rgba(255, 255, 255, .65);
      font-weight: 300;
      margin-bottom: 36px;
    }

    .hero-badges {
      display: flex;
      justify-content: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .badge {
      padding: 6px 16px;
      border: 1px solid rgba(255, 255, 255, .17);
      border-radius: 100px;
      font-size: .74rem;
      font-weight: 500;
      letter-spacing: .05em;
      color: rgba(255, 255, 255, .65);
      transition: all .22s;
    }

    .badge:hover {
      border-color: var(--magenta);
      color: var(--white);
      background: rgba(212, 0, 110, .14);
    }

    /* SEPARATOR */
    .separator {
      background: #e8eef7;
      padding: 40px 24px;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .separator-arrow {
      font-size: 2rem;
      color: #3d4f6a;
      animation: bounce 2s infinite;
    }

    @keyframes bounce {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(10px);
      }
    }

    /* STATS */
    .stats-sec {
      background: linear-gradient(135deg, var(--navy) 0%, var(--blue) 100%);
      padding: 52px 24px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 20px;
      max-width: 1060px;
      margin: 0 auto;
      text-align: center;
    }

    .stat-num {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 900;
      color: var(--white);
      line-height: 1;
      margin-bottom: 8px;
    }

    .stat-num .acc {
      color: var(--pink);
    }

    .stat-lbl {
      font-size: .74rem;
      font-weight: 500;
      color: rgba(255, 255, 255, .48);
      letter-spacing: .07em;
      text-transform: uppercase;
      line-height: 1.4;
    }

    @media(max-width:700px) {
      .stats-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media(max-width:420px) {
      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    /* GENERIC */
    .sec {
      padding: 80px 24px;
    }

    .inn {
      max-width: 1140px;
      margin: 0 auto;
    }

    .sec-hd {
      text-align: center;
      margin-bottom: 56px;
    }

    .lbl {
      display: inline-block;
      font-family: 'Montserrat', sans-serif;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .22em;
      text-transform: uppercase;
      color: var(--magenta);
      margin-bottom: 10px;
    }

    .ttl {
      font-family: 'Montserrat', sans-serif;
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      font-weight: 700;
      color: var(--navy);
      line-height: 1.2;
      margin-bottom: 10px;
    }

    .sub {
      color: var(--mid);
      font-size: .96rem;
      font-weight: 300;
      max-width: 580px;
      margin: 0 auto;
    }

    /* INSTITUTION SECTIONS */
    .inst-sec {
      background: var(--white);
    }

    .inst-sec:nth-child(even) {
      background: var(--off);
    }

    .inst-hd {
      display: flex;
      align-items: flex-start;
      gap: 18px;
      margin-bottom: 28px;
      padding-bottom: 20px;
      border-bottom: 1px solid var(--border);
    }

    .inst-num {
      flex-shrink: 0;
      font-family: 'Montserrat', sans-serif;
      font-size: 3rem;
      font-weight: 900;
      color: var(--blue);
      line-height: 1;
    }

    .inst-info h2 {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.55rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 4px;
    }

    .inst-info .repo {
      font-size: .75rem;
      color: var(--magenta);
      font-weight: 500;
      letter-spacing: .08em;
    }

    .proj-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
      gap: 18px;
    }

    .proj-card {
      background: var(--white);
      border-radius: 14px;
      padding: 26px 24px;
      border: 1px solid var(--border);
      position: relative;
      overflow: hidden;
      transition: transform .28s, box-shadow .28s;
    }

    .inst-sec:nth-child(even) .proj-card {
      background: var(--white);
    }

    .proj-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4px;
      height: 100%;
      background: linear-gradient(to bottom, var(--magenta), var(--blue));
    }

    .proj-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 20px 48px rgba(11, 31, 58, .1);
    }

    .proj-status {
      display: inline-block;
      font-size: .65rem;
      font-weight: 700;
      letter-spacing: .16em;
      text-transform: uppercase;
      padding: 3px 10px;
      border-radius: 100px;
      margin-bottom: 10px;
    }

    .status-active {
      background: rgba(15, 110, 86, .1);
      color: #0f6e56;
    }

    .status-done {
      background: rgba(88, 88, 88, .08);
      color: #5f5e5a;
    }

    .proj-card h3 {
      font-family:'Montserrat', sans-serif;
      font-size: 1.05rem;
      font-weight: 700;
      color: var(--navy);
      margin-bottom: 10px;
      line-height: 1.35;
    }

    .proj-meta {
      display: grid;
      gap: 5px;
      margin-bottom: 12px;
    }

    .proj-meta-row {
      display: flex;
      gap: 8px;
      font-size: .8rem;
    }

    .proj-meta-row .key {
      color: var(--magenta);
      font-weight: 600;
      min-width: 88px;
      flex-shrink: 0;
    }

    .proj-meta-row .val {
      color: var(--mid);
      font-weight: 300;
    }

    .proj-desc {
      font-size: .83rem;
      color: var(--mid);
      font-weight: 300;
      line-height: 1.78;
      border-top: 1px solid var(--border);
      padding-top: 10px;
      margin-top: 2px;
    }

    /* FOOTER */
    footer {
      background: var(--navy);
      color: var(--white);
      padding: 48px 24px 28px;
    }

    .fi {
      max-width: 1140px;
      margin: 0 auto;
    }

    .ft {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 32px;
      flex-wrap: wrap;
      padding-bottom: 28px;
      border-bottom: 1px solid rgba(255, 255, 255, .09);
      margin-bottom: 20px;
    }

    .footer-brand {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.5rem;
      font-weight: 900;
      color: var(--white);
    }

    .footer-brand span {
      color: var(--pink);
    }

    .footer-tag {
      font-size: .88rem;
      color: rgba(255, 255, 255, .42);
      font-weight: 300;
      max-width: 360px;
      line-height: 1.72;
    }

    .fb {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 8px;
    }

    .fb p {
      font-size: .74rem;
      color: rgba(255, 255, 255, .26);
    }

    .footer-logos {
      display: flex;
      gap: 16px;
      align-items: center;
    }

    .footer-logo {
      height: 60px;
      width: auto;
    }
  </style>
</head>


